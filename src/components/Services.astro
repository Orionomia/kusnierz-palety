---
const services = [
  {
    num: '01',
    title: 'Sprzedaż Palet Nowych',
    desc: 'Wykonujemy palety zgodnie ze specyfikacją klienta. Dowolne wymiary, ilości i standardy jakości – od pojedynczych sztuk po duże serie.',
    icon: `<path d="M4 28h40v8H4z" rx="2"/><path d="M4 20h40v6H4z" rx="1"/><rect x="8" y="36" width="8" height="8" rx="1"/><rect x="20" y="36" width="8" height="8" rx="1"/><rect x="32" y="36" width="8" height="8" rx="1"/><line x1="4" y1="12" x2="44" y2="12"/><line x1="4" y1="16" x2="44" y2="16"/>`,
    iconVB: '0 0 48 48',
  },
  {
    num: '02',
    title: 'Skup Palet Używanych',
    desc: 'Skupujemy palety jednorazowe, przemysłowe i Euro w każdym stanie. Szybka bezpłatna wycena i odbiór bezpośrednio od klienta.',
    icon: `<polyline points="17 1 21 1 21 5"/><polyline points="7 23 3 23 3 19"/><path d="M21 9v10a2 2 0 0 1-2 2H3"/><path d="M3 15V5a2 2 0 0 1 2-2h10"/>`,
    iconVB: '0 0 24 24',
  },
  {
    num: '03',
    title: 'Naprawa Palet',
    desc: 'Profesjonalna naprawa palet drewnianych. Przywracamy pełną sprawność techniczną i przedłużamy żywotność nawet mocno zużytych palet.',
    icon: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
    iconVB: '0 0 24 24',
  },
  {
    num: '04',
    title: 'Magazynowanie',
    desc: 'Duże zaplecze magazynowe zapewnia stałą dostępność towaru i sprawną realizację nawet dużych, wielotysięcznych zamówień.',
    icon: `<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
    iconVB: '0 0 24 24',
  },
];
---

<section class="section services" id="oferta">
  <div class="container">
    <header class="services-header">
      <div>
        <p class="tag">Czym się zajmujemy</p>
        <h2 class="display services-title">Nasza Oferta</h2>
      </div>
      <p class="services-subtitle">
        Kompleksowa obsługa w zakresie obrotu paletami drewnianymi
        dla firm i klientów indywidualnych.
      </p>
    </header>

    <ul class="services-grid" role="list">
      {services.map((s) => (
        <li class="service-card">
          <div class="service-top">
            <span class="service-num mono">{s.num} /</span>
            <span class="service-icon" aria-hidden="true">
              <svg viewBox={s.iconVB} fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={s.icon} />
              </svg>
            </span>
          </div>
          <h3 class="service-title display">{s.title}</h3>
          <p class="service-desc">{s.desc}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
.services { background: #111; }

.services-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 32px;
  margin-bottom: 56px;
  flex-wrap: wrap;
}
.services-title { font-size: clamp(50px, 5.5vw, 76px); }
.services-subtitle {
  font-size: 15px;
  color: var(--muted);
  max-width: 340px;
  font-weight: 300;
  line-height: 1.7;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: rgba(240,170,48,0.08);
  border: 1px solid rgba(240,170,48,0.08);
  border-radius: var(--radius);
  overflow: hidden;
}

.service-card {
  background: #111;
  padding: 44px 36px;
  position: relative;
  overflow: hidden;
  transition: background var(--transition);
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.service-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 3px;
  height: 0;
  background: var(--oak);
  transition: height 0.4s ease;
}
.service-card:hover { background: rgba(240,170,48,0.05); }
.service-card:hover::before { height: 100%; }

.service-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}
.service-num { color: rgba(240,170,48,0.35); }
.service-icon {
  width: 44px;
  height: 44px;
  color: var(--oak);
  padding: 10px;
  background: rgba(240,170,48,0.08);
  border-radius: var(--radius);
}
.service-icon svg { width: 100%; height: 100%; }

.service-title {
  font-size: 29px;
  color: var(--white);
  line-height: 1.1;
}
.service-desc {
  font-size: 15px;
  color: var(--muted);
  line-height: 1.75;
  font-weight: 300;
  flex: 1;
}


@media (max-width: 768px) {
  .services-header { flex-direction: column; align-items: flex-start; }
  .services-grid { grid-template-columns: 1fr; }
}
</style>
