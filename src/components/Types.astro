---
const types = [
  {
    label: 'Standard',
    name: 'Palety Euro',
    desc: 'Standardowe palety EUR/EPAL stosowane powszechnie w handlu i logistyce europejskiej. Certyfikowana jakość, precyzyjna konstrukcja.',
    dims: '1200 × 800 mm',
    load: 'Nośność do 1500 kg',
    color: '#F0AA30',
    features: ['Certyfikat EPAL', 'Drewno iglaste', 'Fumigowane wg ISPM 15'],
  },
  {
    label: 'Przemysłowe',
    name: 'Palety Przemysłowe',
    desc: 'Wytrzymałe palety do zastosowań przemysłowych. Dostępne w różnych wymiarach i konfiguracjach, dopasowane do potrzeb produkcji i logistyki.',
    dims: 'Wymiary na zamówienie',
    load: 'Nośność do 3000 kg',
    color: '#F0AA30',
    features: ['Produkcja na miarę', 'Wysoka wytrzymałość', 'Różne konfiguracje'],
  },
  {
    label: 'Eksport / Jednorazowe',
    name: 'Palety Jednorazowe',
    desc: 'Lekkie palety jednorazowego użytku, idealne do eksportu i jednorazowych transportów. Ekonomiczne i funkcjonalne rozwiązanie logistyczne.',
    dims: 'Różne rozmiary',
    load: 'Produkcja na zamówienie',
    color: '#F0AA30',
    features: ['Niski koszt jednostkowy', 'Lekka konstrukcja', 'Szybka realizacja'],
  },
];
---

<section class="section types" id="palety">
  <div class="container">
    <p class="tag">Asortyment</p>
    <h2 class="display types-title">Rodzaje Palet</h2>
    <p class="types-intro">
      Oferujemy pełny zakres palet drewnianych – nowych i używanych –
      dopasowanych do wymagań każdej branży.
    </p>

    <div class="types-grid">
      {types.map((t, i) => (
        <article class="type-card" style={`--accent: ${t.color};`}>
          <div class="type-header">
            <span class="type-label mono">{t.label}</span>
            <span class="type-index mono">{String(i + 1).padStart(2, '0')}</span>
          </div>
          <h3 class="display type-name">{t.name}</h3>
          <p class="type-desc">{t.desc}</p>

          <ul class="type-features" role="list">
            {t.features.map((f) => (
              <li class="type-feature">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>

          <div class="type-footer">
            <div class="type-dim">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 3H3v18h18V3zM3 9h18M9 21V9"/></svg>
              {t.dims}
            </div>
            <div class="type-dim">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22c-4.97 0-9-2.24-9-5V7"/><path d="M3 7c0-2.76 4.03-5 9-5s9 2.24 9 5v10c0 2.76-4.03 5-9 5"/><path d="M3 12c0 2.76 4.03 5 9 5s9-2.24 9-5"/></svg>
              {t.load}
            </div>
          </div>
          <div class="type-bar" aria-hidden="true"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.types { background: var(--charcoal); }
.types-title { font-size: clamp(50px, 5.5vw, 76px); margin-bottom: 16px; }
.types-intro {
  font-size: 18px;
  color: var(--muted);
  font-weight: 300;
  max-width: 520px;
  margin-bottom: 56px;
  line-height: 1.7;
}

.types-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
}

.type-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(240,170,48,0.1);
  border-radius: var(--radius);
  padding: 40px 32px 32px;
  display: flex;
  flex-direction: column;
  gap: 18px;
  position: relative;
  overflow: hidden;
  transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
}
.type-card:hover {
  transform: translateY(-6px);
  border-color: var(--accent, var(--oak));
  box-shadow: 0 24px 60px rgba(0,0,0,0.35);
}

.type-bar {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--accent, var(--oak)), color-mix(in srgb, var(--accent, var(--oak)) 60%, white));
  transform: scaleX(0);
  transition: transform 0.35s ease;
  transform-origin: left;
}
.type-card:hover .type-bar { transform: scaleX(1); }

.type-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.type-label {
  color: var(--accent, var(--oak));
  border: 1px solid rgba(240,170,48,0.25);
  padding: 3px 10px;
  border-radius: 1px;
  border-color: var(--accent, var(--oak));
  opacity: 0.85;
}
.type-index { color: rgba(255,255,255,0.15); font-size: 13px; }

.type-name { font-size: 33px; color: var(--white); line-height: 1.05; }
.type-desc { font-size: 14px; color: var(--muted); line-height: 1.75; font-weight: 300; flex: 1; }

.type-features { display: flex; flex-direction: column; gap: 8px; }
.type-feature {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: rgba(253,250,246,0.6);
}
.type-feature svg { color: var(--accent, var(--oak)); flex-shrink: 0; }

.type-footer {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding-top: 16px;
  border-top: 1px solid rgba(255,255,255,0.07);
}
.type-dim {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.1em;
  color: rgba(240,170,48,0.6);
}

@media (max-width: 768px) {
  .types-grid { grid-template-columns: 1fr; }
}
</style>
