---

<section class="hero" aria-label="Strona główna – Kuśnierz Palety">
  <div class="hero-left">
    <p class="tag animate-up">Kościerzyna · Polska</p>
    <h1 class="hero-title display animate-up delay-1">
      Skup<br />i Sprzedaż<br /><em>Palet</em>
    </h1>
    <p class="hero-desc animate-up delay-2">
      Profesjonalna obsługa, terminowe dostawy i konkurencyjne ceny.
      Nowe palety na zamówienie, skup i sprzedaż palet używanych,
      naprawa drewnianych palet.
    </p>
    <div class="hero-btns animate-up delay-3">
      <a href="#kontakt" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.41 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6.29 6.29l.87-.87a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Zadzwoń teraz
      </a>
      <a href="#oferta" class="btn btn-outline">
        Nasza oferta
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>

    <div class="hero-stats animate-up delay-4">
      <div class="stat">
        <span class="stat-num">10+</span>
        <span class="stat-label">lat doświadczenia</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-num">24H</span>
        <span class="stat-label">czas realizacji</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-num">100%</span>
        <span class="stat-label">zadowolenia</span>
      </div>
    </div>
  </div>

  <!-- Ikony branżowe po prawej — ukryte na mobile -->
  <div class="hero-right" aria-hidden="true">
    <div class="hero-icons-grid">

      <div class="hero-icon-item">
        <div class="hero-icon-box">
          <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="16" width="40" height="7" rx="1"/>
            <rect x="4" y="9" width="40" height="6" rx="1"/>
            <rect x="4" y="23" width="40" height="6" rx="1"/>
            <rect x="7"  y="29" width="8" height="10" rx="1"/>
            <rect x="20" y="29" width="8" height="10" rx="1"/>
            <rect x="33" y="29" width="8" height="10" rx="1"/>
            <rect x="4"  y="39" width="40" height="4" rx="1"/>
          </svg>
        </div>
        <span>Palety Euro</span>
      </div>

      <div class="hero-icon-item">
        <div class="hero-icon-box">
          <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="12" width="28" height="22" rx="2"/>
            <path d="M32 18h6l6 9v7H32V18z"/>
            <circle cx="12" cy="38" r="4"/>
            <circle cx="38" cy="38" r="4"/>
            <line x1="16" y1="38" x2="34" y2="38"/>
          </svg>
        </div>
        <span>Dostawa</span>
      </div>

      <div class="hero-icon-item">
        <div class="hero-icon-box">
          <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 22L24 10l20 12v24H4V22z"/>
            <rect x="17" y="30" width="14" height="16" rx="1"/>
            <line x1="4" y1="22" x2="44" y2="22"/>
            <line x1="24" y1="10" x2="24" y2="22"/>
          </svg>
        </div>
        <span>Magazyn</span>
      </div>

      <div class="hero-icon-item">
        <div class="hero-icon-box">
          <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M38 6a9 9 0 0 0-9 9c0 1.7.5 3.3 1.3 4.7L8 42a3.5 3.5 0 0 0 5 5l22-21.3A9 9 0 1 0 38 6z"/>
            <line x1="31" y1="13" x2="35" y2="17"/>
          </svg>
        </div>
        <span>Naprawa</span>
      </div>

      <div class="hero-icon-item">
        <div class="hero-icon-box">
          <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M24 4l3.5 7.5 8.5 1.2-6 6 1.4 8.3-7.4-4-7.4 4 1.4-8.3-6-6 8.5-1.2z"/>
            <line x1="17" y1="30" x2="13" y2="44"/>
            <line x1="31" y1="30" x2="35" y2="44"/>
            <line x1="13" y1="44" x2="35" y2="44"/>
          </svg>
        </div>
        <span>Certyfikat EPAL</span>
      </div>

      <div class="hero-icon-item">
        <div class="hero-icon-box">
          <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="10" y1="8" x2="10" y2="36"/>
            <rect x="10" y="16" width="18" height="14" rx="1"/>
            <line x1="28" y1="23" x2="38" y2="23"/>
            <line x1="10" y1="36" x2="40" y2="36"/>
            <circle cx="16" cy="41" r="4"/>
            <circle cx="32" cy="41" r="4"/>
            <line x1="36" y1="10" x2="36" y2="23"/>
          </svg>
        </div>
        <span>Wózek widłowy</span>
      </div>

    </div>
  </div>
</section>

<style>
.hero {
  min-height: 100svh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding-top: 72px;
  background:
    repeating-linear-gradient(88deg,
      transparent, transparent 18px,
      rgba(240,170,48,0.03) 19px, rgba(240,170,48,0.03) 20px),
    repeating-linear-gradient(92deg,
      transparent, transparent 30px,
      rgba(59,42,26,0.08) 31px, rgba(59,42,26,0.08) 32px),
    var(--charcoal);
}

/* ── LEFT ── */
.hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: clamp(40px, 5vw, 80px) clamp(24px, 5vw, 64px);
}

.hero-title {
  font-size: clamp(76px, 8.5vw, 128px);
  color: var(--white);
  margin-bottom: 28px;
}
.hero-title em {
  font-style: normal;
  color: var(--oak);
}

.hero-desc {
  font-size: clamp(17px, 1.4vw, 19px);
  color: var(--muted);
  max-width: 460px;
  margin-bottom: 40px;
  font-weight: 300;
  line-height: 1.75;
}

.hero-btns {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-bottom: 56px;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 28px;
  padding: 28px 0 0;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.stat { display: flex; flex-direction: column; gap: 4px; }
.stat-num {
  font-family: var(--font-display);
  font-size: 40px;
  color: var(--oak);
  line-height: 1;
}
.stat-label {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(253,250,246,0.35);
}
.stat-divider {
  width: 1px;
  height: 36px;
  background: rgba(255,255,255,0.1);
}

/* ── RIGHT — ikony ── */
.hero-right {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: clamp(40px, 5vw, 80px) clamp(32px, 4vw, 64px);
  border-left: 1px solid rgba(240,170,48,0.08);
}

.hero-icons-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: clamp(16px, 2vw, 28px);
  width: 100%;
}

.hero-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  text-align: center;
}

.hero-icon-box {
  width: 100%;
  aspect-ratio: 1;
  border: 1px solid rgba(240,170,48,0.18);
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--oak);
  background: rgba(240,170,48,0.04);
  transition: border-color var(--transition), background var(--transition), transform var(--transition);
}
.hero-icon-box svg {
  width: 45%;
  height: 45%;
}
.hero-icon-item:hover .hero-icon-box {
  border-color: rgba(240,170,48,0.45);
  background: rgba(240,170,48,0.09);
  transform: translateY(-4px);
}

.hero-icon-item span {
  font-family: var(--font-mono);
  font-size: clamp(9px, 0.8vw, 11px);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(253,250,246,0.35);
  line-height: 1.3;
}

/* ── MOBILE — ukryj prawą kolumnę ── */
@media (max-width: 900px) {
  .hero { grid-template-columns: 1fr; }
  .hero-right { display: none; }
  .hero-left { padding-top: 40px; padding-bottom: 64px; }
  .hero-stats { gap: 18px; }
}
</style>
