---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Kuśnierz Palety – Skup i Sprzedaż Palet | Kościerzyna',
  description = 'Profesjonalny skup, sprzedaż i naprawa palet drewnianych w Kościerzynie. Palety Euro, przemysłowe, jednorazowe. Szybka obsługa, konkurencyjne ceny.'
} = Astro.props;
---

<!doctype html>
<html lang="pl">
<head>
  <!-- Charset & Viewport -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Waldemar Kuśnierz" />
  <meta name="creator" content="Orionomia" />
  <meta name="keywords" content="palety drewniane, skup palet, sprzedaż palet, naprawa palet, palety euro, palety EPAL, palety przemysłowe, palety jednorazowe, palety używane, palety nowe, Kuśnierz Palety, Kościerzyna, Pomorskie, Polska, hurtownia palet, producent palet, transport palet, palety na zamówienie" />

  <!-- Open Graph (Facebook, LinkedIn) -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://kusnierzpalety.eu/" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="pl_PL" />
  <meta property="og:site_name" content="Kuśnierz Palety" />
  <meta property="og:image" content="https://kusnierzpalety.eu/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/jpeg" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Geo / Local SEO -->
  <meta name="geo.region" content="PL-PM" />
  <meta name="geo.placename" content="Kościerzyna" />

  <!-- Theme & Icons -->
  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#1C1C1C" />
  <link rel="canonical" href="https://kusnierzpalety.eu/" />
</head>
<body>

  <!-- ── NAV ── -->
  <header class="nav-wrapper" id="nav">
    <nav class="container nav-inner">
      <a href="#" class="nav-logo" aria-label="Kuśnierz Palety">
        <img
          src="/logo.svg"
          alt="Kuśnierz Palety Logo"
          class="nav-logo-icon"
        />
        <span class="nav-logo-text">Kuśnierz Palety</span>
      </a>
      <ul class="nav-links" role="list">
        <li><a href="#oferta"  class="nav-link">Oferta</a></li>
        <li><a href="#palety"  class="nav-link">Rodzaje palet</a></li>
        <li><a href="#o-nas"   class="nav-link">O nas</a></li>
        <li><a href="#kontakt" class="nav-link nav-cta">Kontakt</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <!-- ── FOOTER ── -->
  <footer class="footer">
    <div class="container footer-inner">

      <div class="footer-brand">
        <div class="footer-logo-wrap">
          <img
            src="/logo.svg"
            alt="Kuśnierz Palety Logo"
            class="footer-logo-icon"
          />
          <span class="footer-logo-text">Kuśnierz Palety</span>
        </div>
        <p class="footer-tagline">Profesjonalny skup i sprzedaż<br/>palet drewnianych.</p>
      </div>

      <nav class="footer-nav" aria-label="Nawigacja stopki">
        <p class="footer-nav-title">Menu</p>
        <ul role="list">
          <li><a href="#oferta">Oferta</a></li>
          <li><a href="#palety">Rodzaje palet</a></li>
          <li><a href="#o-nas">O nas</a></li>
          <li><a href="#kontakt">Kontakt</a></li>
        </ul>
      </nav>

      <div class="footer-contact">
        <p class="footer-nav-title">Kontakt</p>
        <a href="tel:+48888966017" class="footer-contact-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.41 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6.29 6.29l.87-.87a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          +48 888 966 017
        </a>
        <a href="mailto:palety.koscierzyna@gmail.com" class="footer-contact-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          palety.koscierzyna@gmail.com
        </a>
        <p class="footer-contact-text">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          Kościerzyna, Polska
        </p>
      </div>

    </div>

    <div class="footer-bottom">
      <div class="container footer-bottom-inner">
        <p class="footer-copy">© 2015–2026 KUŚNIERZ PALETY · Waldemar Kuśnierz · Serwis korzysta z plików cookies.</p>
        <p class="footer-copy">Projekt i realizacja: <a href="mailto:orionomia@gmail.com" class="footer-ori-link">Orionomia</a></p>
      </div>
    </div>
  </footer>


<script>
// Touch hover support for iOS Safari
document.querySelectorAll(
  '.service-card, .type-card, .feature, .contact-card, .hero-icon-item'
).forEach(el => {
  el.addEventListener('touchstart', () => el.classList.add('touch-hover'), { passive: true });
  el.addEventListener('touchend',   () => setTimeout(() => el.classList.remove('touch-hover'), 300), { passive: true });
});
</script>

</body>
</html>

<style>
/* ── NAV ── */
.nav-wrapper {
  position: fixed;
  inset-inline: 0;
  top: 0;
  z-index: 200;
  background: rgba(20,20,20,0.88);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(240,170,48,0.18);
  transition: background 0.3s;
}
.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72px;
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 12px;
}
.nav-logo-icon {
  height: 48px;
  width: auto;
  object-fit: contain;
  filter: drop-shadow(0 0 8px rgba(240,170,48,0.35));
  transition: filter 0.2s;
  flex-shrink: 0;
}
.nav-logo:hover .nav-logo-icon { filter: drop-shadow(0 0 14px rgba(240,170,48,0.6)); }
.nav-logo-text {
  font-family: var(--font-display);
  font-size: 24px;
  color: var(--oak);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  line-height: 1;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 32px;
}
.nav-link {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--muted);
  transition: color var(--transition);
}
.nav-link:hover { color: var(--oak-light); }
.nav-cta {
  background: var(--oak);
  color: var(--charcoal);
  padding: 10px 22px;
  border-radius: var(--radius);
  font-weight: 700;
}
.nav-cta:hover { background: var(--oak-light); color: var(--charcoal); }
/* Override nav-link color for cta */
a.nav-link.nav-cta { color: var(--charcoal); }
a.nav-link.nav-cta:hover { color: var(--charcoal); }

/* ── FOOTER ── */
.footer {
  background: var(--ink);
  border-top: 1px solid rgba(240,170,48,0.12);
}
.footer-inner {
  display: grid;
  grid-template-columns: 2fr 1fr 2fr;
  gap: 48px;
  padding-block: 64px;
  align-items: start;
}
.footer-logo-wrap {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}
.footer-logo-icon {
  height: 48px;
  width: auto;
  flex-shrink: 0;
}
.footer-logo-text {
  font-family: var(--font-display);
  font-size: 24px;
  color: var(--oak);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  line-height: 1;
}
.footer-tagline {
  font-size: 14px;
  color: var(--muted);
  line-height: 1.6;
  font-weight: 300;
}
.footer-nav-title {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--oak);
  margin-bottom: 16px;
}
.footer-nav ul {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.footer-nav a {
  font-size: 14px;
  color: var(--muted);
  transition: color 0.2s;
}
.footer-nav a:hover { color: var(--white); }
.footer-contact {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.footer-contact-link,
.footer-contact-text {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: var(--muted);
  transition: color 0.2s;
}
a.footer-contact-link:hover { color: var(--oak-light); }

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.06);
  padding-block: 20px;
}
.footer-bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px 24px;
}
.footer-copy {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.06em;
  color: rgba(253,250,246,0.35);
}
.footer-ori-link {
  color: rgba(253,250,246,0.25);
  text-decoration: none;
  transition: color 0.2s;
}
.footer-ori-link:hover { color: rgba(253,250,246,0.55); }

/* ── RESPONSIVE ── */
@media (max-width: 860px) {
  .nav-links { gap: 18px; }
  .nav-link { font-size: 10px; letter-spacing: 0.1em; }
}
@media (max-width: 640px) {
  .nav-links { gap: 12px; }
  .nav-link:not(.nav-cta) { display: none; }
  .nav-cta { display: flex; }
  .footer-inner { grid-template-columns: 1fr; gap: 32px; padding-block: 40px; }
  .footer-bottom-inner { flex-direction: column; align-items: flex-start; }
}
</style>

<script>
// Scroll-triggered nav background
const nav = document.getElementById('nav');
if (nav) {
  window.addEventListener('scroll', () => {
    nav.style.background = window.scrollY > 40
      ? 'rgba(10,10,10,0.97)'
      : 'rgba(20,20,20,0.88)';
  }, { passive: true });
}

// Smooth scroll for all anchor links
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
  anchor.addEventListener('click', (e) => {
    const href = (anchor as HTMLAnchorElement).getAttribute('href');
    if (!href || href === '#') return;
    const target = document.querySelector(href);
    if (target) {
      e.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });
});
</script>
